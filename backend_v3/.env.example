# ==========================================================================
# AI Video Dubbing Platform V3.0 - Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# On Render, set these under the service's "Environment" tab instead.
# ==========================================================================

# --- Application ---------------------------------------------------------
DEBUG=false
ENVIRONMENT=production

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# --- Groq Whisper (Speech-to-Text) -----------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3

# --- Uploads -----------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=500

# --- Task Lifecycle ------------------------------------------------------------
TASK_EXPIRY_HOURS=24
TASK_CLEANUP_INTERVAL_MINUTES=30

# --- Logging --------------------------------------------------------------------
LOG_LEVEL=INFO
