# ==========================================================================
# AI Video Dubbing Platform V3.0 - Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# On Render, set these under the service's "Environment" tab instead.
# ==========================================================================

# --- Application ---------------------------------------------------------
DEBUG=false
ENVIRONMENT=production

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=10000
CORS_ORIGINS=*

# --- Groq Whisper (Speech-to-Text) -----------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3

# --- Text-to-Speech: Multi-Engine (V3.1 LTS) --------------------------------
# Registered engine names: gtts | edge | azure | piper | xtts | elevenlabs
# DEFAULT_TTS_ENGINE=gtts -- zero-config default; needs no API key/binary/model.
# FALLBACK_TTS_ENGINES is a comma-separated ORDERED chain, tried left to right,
# skipping any engine that's unavailable/unconfigured, until one succeeds.
DEFAULT_TTS_ENGINE=gtts
FALLBACK_TTS_ENGINES=edge,azure,piper,xtts,elevenlabs

# gTTS -- no credentials required.
GTTS_DEFAULT_TLD=com
GTTS_SLOW=false

# Azure Cognitive Services Speech -- leave blank to keep the engine disabled
# (it will report "unavailable" from GET /tts/engines instead of erroring).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ElevenLabs -- leave blank to keep the engine disabled.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Piper (local; requires requirements-optional.txt + a downloaded binary and
# .onnx models -- NOT recommended on Render's free tier). Map language codes
# to model filenames (relative to PIPER_MODEL_DIR) as a JSON object, e.g.:
#   PIPER_VOICE_MODEL_MAP={"en":"en_US-lessac-medium.onnx","hi":"hi_IN-pratham-medium.onnx"}
PIPER_BINARY_PATH=piper
PIPER_MODEL_DIR=storage/tts_models/piper
PIPER_VOICE_MODEL_MAP={}

# XTTS v2 / Coqui (local voice cloning; requires requirements-optional.txt --
# NOT recommended on Render's free tier). Needs a reference speaker .wav.
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_DEVICE=cpu
XTTS_DEFAULT_SPEAKER_WAV=

# --- Uploads -----------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=500

# --- Task Lifecycle ------------------------------------------------------------
TASK_EXPIRY_HOURS=24
TASK_CLEANUP_INTERVAL_MINUTES=30

# --- Logging --------------------------------------------------------------------
LOG_LEVEL=INFO
